<%- include('header',{title:"Post Management"}) %>
    <div class="page-wrapper">
        <h1 class="title">Post Management</h1>
        <a href="/add" class="add-btn">+ Add New Post</a>
        <div class="table-wrap">
            <table>
                <tr>
                    <th>Image</th>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Price</th>
                    <th>Author</th>
                    <th>Publish Date</th>
                    <th>Action</th>
                </tr>
                <% books.forEach((b)=>{ %>
                    <tr>
                        <td><img src="<%= b.image %>" alt="<%= b.title %>" width="80" height="80"></td>
                        <td><%= b.title %></td>
                        <td><%= b.description %></td>
                        <td>₹<%= b.price %></td>
                        <td><%= b.author %></td>
                        <td><%= b.publish_date %></td>
                        <td>
                            <a href="/edit/<%= b.id %>">Edit</a>
                            <form action="/delete/<%= b.id %>" method="POST" style="display:inline; margin-left:8px;">
                                <button type="submit" onclick="return confirm('Delete this book?');">Delete</button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
            </table>
        </div>
    </div>